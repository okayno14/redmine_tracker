{erl_opts, [debug_info]}.

{deps, [
    {meck, "1.1.0"},
    {erl_utils, {git, "https://github.com/okayno14/erl_utils.git", {branch, "v2"}}},
    {observer_cli, {git, "https://github.com/zhongwencool/observer_cli.git", {tag, "1.8.7"}}}
]}.

{shell, [
  {config, "config/sys.config"},
  {apps, [redmine_tracker]}
]}.


{escript_incl_apps, [erl_utils]}.
% {escript_main_app, foo}.
{escript_name, redmine_tracker_ctl}.
{escript_emu_args, "%%! +sbtu +A1\n"}.

{profiles, [
  {test, [
    % {ct_opts, [{sys_config, "config/test.config"}]},
    {eunit_opts, [{sys_config, "config/sys.config"}]}
  ]}
]}.
